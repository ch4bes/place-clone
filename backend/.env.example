# Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# FIREBASE CONFIGURATION
# Get these from Firebase Console:
# https://console.firebase.google.com
# ============================================

FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_PROJECT_ID=your-project-id

# ============================================
# ADMIN CONFIGURATION
# Set a secure password for admin panel access
# ============================================

ADMIN_PASSWORD=your_secure_admin_password

# ============================================
# SERVER CONFIGURATION
# ============================================

NODE_ENV=production
# Port is automatically assigned by Render
# PORT=3000

# Replace with your actual Neocities URL
CORS_ORIGIN=https://chabes.neocities.org/place

# ============================================
# BOT DETECTION CONFIGURATION
# ============================================

# Number of days to retain behavior logs
BOT_LOG_RETENTION_DAYS=7

# Enable automatic cleanup of old logs
AUTO_CLEANUP_ENABLED=true

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Create Firebase project at https://console.firebase.google.com
# 3. Enable Realtime Database in test mode
# 4. Copy your Firebase config values above
# 5. Set a strong admin password
# 6. Update CORS_ORIGIN with your Neocities URL
# 7. Deploy to Render and set environment variables there
